# Example environment file for RP-clock-miner
# Copy this to .env and update with your values

# ===== Mining mode =====
# solo = mine against your own local bitcoind node (needs full blockchain sync)
# pool = mine against SoloPool.org via Stratum (no local node required)
# Leave unset to use the "mode" value from miner/config.json.
#MINING_MODE=solo

# Pool overrides (only used when MINING_MODE=pool). Defaults come from
# miner/config.json "pool" section. region: eu|us, tier: low|mid|high.
#POOL_REGION=eu
#POOL_TIER=low
#POOL_WORKER_ID=rpi5

# ===== RPC Authentication for Bitcoin Core (solo mode only) =====
# You can use any username/password combination you want
# Just make sure they're secure and match in bitcoin.conf
BITCOIN_RPC_USER=rpiminer
BITCOIN_RPC_PASSWORD=change_this_to_something_secure_123456

# Your Bitcoin address where mining rewards will be sent
# IMPORTANT: Use your own address! This is just a FAKE EXAMPLE address
# DO NOT use this address - any coins sent here will be lost
# Get your address from a trusted wallet (hardware wallet recommended)
BITCOIN_MINING_ADDRESS=bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh

# WiFi Configuration (optional)
# Leave empty to skip WiFi setup
WIFI_SSID=YourWiFiNetworkName
WIFI_PASSWORD=YourWiFiPassword

# Optional: Email for notifications (leave empty if not using)
NOTIFICATION_EMAIL=

# Optional: Telegram bot for mining notifications
# Get bot token from @BotFather on Telegram
# Get chat ID from https://api.telegram.org/bot<TOKEN>/getUpdates after messaging your bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Note: All other settings are in miner/config.json
